<style>
/* ── Status Badges ────────────────────────────────────────── */
.status-badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 700;
  font-family: var(--font-mono);
}
.status-200 { background: rgba(16,185,129,0.15); color: #10b981; }
.status-400 { background: rgba(245,158,11,0.15); color: #f59e0b; }
.status-404 { background: rgba(59,130,246,0.15); color: #3b82f6; }
.status-429 { background: rgba(99,102,241,0.15); color: #818cf8; }
.status-502, .status-50x { background: rgba(239,68,68,0.15); color: #ef4444; }

/* ── Featured default endpoint card ──────────────────────── */
#ep-default-feature { overflow: visible !important; }
#ep-default-feature .unified-rec-badge {
  position: absolute;
  top: 0; right: 16px;
  transform: translateY(-50%);
  z-index: 6;
  background: var(--accent);
  color: #000;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 2px 10px;
  border-radius: 20px;
  letter-spacing: 0.05em;
  border: 1px solid rgba(0,0,0,0.12);
  box-shadow: 0 4px 12px rgba(245,158,11,0.35);
}

/* ── Endpoint tag pills ─────────────────────────────────── */
.ep-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.75rem;
  padding: 3px 10px;
  border-radius: 12px;
  border: 1px solid transparent;
}
.ep-tag-accent  { background:rgba(245,158,11,0.12); color:var(--accent);  border-color:rgba(245,158,11,0.3); }
.ep-tag-indigo  { background:rgba(99,102,241,0.12);  color:#818cf8;        border-color:rgba(99,102,241,0.3); }
.ep-tag-emerald { background:rgba(52,211,153,0.12);  color:#34d399;        border-color:rgba(52,211,153,0.3); }
.ep-tag-blue    { background:rgba(59,130,246,0.12);  color:#60a5fa;        border-color:rgba(59,130,246,0.3); }

/* ── Endpoint Accordion (section 03 list) ─────────────────── */
.ep-accordion {
  border: 1px solid var(--bg-border);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
  overflow: hidden;
  background: var(--bg-surface);
  transition: border-color var(--transition), transform var(--transition);
}
.ep-accordion:hover { border-color: rgba(255,99,0,0.35); }

.ep-accordion-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px var(--space-lg);
  background: var(--bg-surface);
  border: none;
  cursor: pointer;
  text-align: left;
  gap: var(--space-sm);
  transition: background var(--transition);
}
.ep-accordion-header:hover { background: var(--bg-elevated); }

.ep-accordion-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-wrap: wrap;
  min-width: 0;
}

.ep-chevron {
  flex-shrink: 0;
  color: var(--text-muted);
  transition: transform 0.25s ease, color var(--transition);
}
.ep-accordion.open .ep-chevron { transform: rotate(180deg); }
.ep-accordion.open .ep-chevron { color: var(--accent); }

.ep-accordion-body {
  display: none;
  padding: var(--space-lg);
  border-top: 1px solid var(--bg-border);
  background: var(--bg-base);
}
.ep-accordion.open .ep-accordion-body { display: block; }

/* Badge labels on endpoint rows */
.ep-badge-recommended {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  background: rgba(245,158,11,0.12);
  color: var(--accent);
  border: 1px solid rgba(245,158,11,0.3);
  letter-spacing: 0.02em;
}
.ep-badge-slow {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  background: rgba(251,146,60,0.1);
  color: #fb923c;
  border: 1px solid rgba(251,146,60,0.3);
}
.ep-badge-info {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  background: rgba(52,211,153,0.1);
  color: #34d399;
  border: 1px solid rgba(52,211,153,0.3);
}

/* ── Lucide icons sizing ──────────────────────────────────── */
.lucide-icon, i[data-lucide] {
  display: inline-flex;
  align-items: center;
  vertical-align: middle;
  flex-shrink: 0;
}

/* Terminal done dot — use CSS circle instead of emoji */
.pc-done-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--status-ok, #22c55e);
  flex-shrink: 0;
}
</style>

<%- include('partials/footer', { extraScripts: `
<script src="/js/copy.js"></script>
<script src="/js/playground-anim.js"></script>
<script>
  // Accordion for endpoint cards
  document.querySelectorAll('.ep-accordion-header').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var acc = btn.closest('.ep-accordion');
      var isOpen = acc.classList.contains('open');
      acc.classList.toggle('open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Raw JSON accordions in Schema section
  document.querySelectorAll('[id^="exAccordionToggle"]').forEach(function(toggle) {
    toggle.addEventListener('click', function() {
      var accId = toggle.id.replace('Toggle', '');
      var acc = document.getElementById(accId);
      if (!acc) return;
      acc.classList.toggle('open');
      var expanded = acc.classList.contains('open');
      toggle.setAttribute('aria-expanded', String(expanded));
    });
    toggle.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle.click(); }
    });
  });

  // Demo terminal init via IntersectionObserver
  (function() {
    var started = false;
    var section = document.getElementById('demo');
    if (!section) return;
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting && !started) {
          started = true;
          if (typeof runAnimation === 'function') runAnimation();
        }
      });
    }, { threshold: 0.25 });
    io.observe(section);
  })();
</script>` }) %>
