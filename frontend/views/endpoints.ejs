          <!-- Hero card cho /api/fuel-prices -->
          <div id="ep-default-feature" class="endpoint-card" style="border-color:var(--accent);border-width:2px;position:relative;">
            <span class="unified-rec-badge"
                  data-vi="KHUYẾN NGHỊ" data-en="RECOMMENDED">KHUYẾN NGHỊ</span>
            <div class="endpoint-header">
              <span class="method-badge method-get">GET</span>
              <code class="endpoint-path">/api/fuel-prices</code>
            </div>
            <p class="endpoint-desc"
               data-vi="Default: gom nhóm dữ liệu từ 11 nguồn (bao gồm mirror Petrolimex, COMECO, SaigonPetro, Petrotimes...) thành một cấu trúc chuẩn, có nhãn source cho từng mức giá."
               data-en="Default: groups data from 11 sources (including Petrolimex mirrors, COMECO, SaigonPetro, Petrotimes...) into a single standardized schema with per-price source labels.">
              <strong>Default Endpoint</strong>: dữ liệu đầy đủ từ <strong>11 nguồn</strong>, trả về theo dạng <code>data[] -> sources[]</code>.
            </p>

            <div style="display:flex;flex-wrap:wrap;gap:8px;margin:12px 0;">
              <span class="ep-tag ep-tag-accent">
                <i data-lucide="database" width="11" height="11"></i>
                11 nguồn tích hợp
              </span>
              <span class="ep-tag ep-tag-indigo">
                <i data-lucide="tag" width="11" height="11"></i>
                Nhãn source từng giá
              </span>
              <span class="ep-tag ep-tag-emerald">
                <i data-lucide="layers" width="11" height="11"></i>
                Grouped theo mặt hàng
              </span>
              <span class="ep-tag ep-tag-blue">
                <i data-lucide="zap" width="11" height="11"></i>
                60 req/min
              </span>
            </div>

            <div class="code-block">
              <div class="code-header"><span class="code-lang">JavaScript (Fetch)</span><button class="copy-btn" data-target="ep-default-js">Copy</button></div>
              <pre id="ep-default-js"><code>const res = await fetch('http://localhost:3000/api/fuel-prices');
const json = await res.json();

console.log(json.meta.dataSources.length); // 11
console.log(json.data[0].name);            // "Xăng RON 95-V"
console.log(json.data[0].sources);         // [{ source, region1, region2, price }, ...]</code></pre>
            </div>

            <div class="code-block" style="margin-top:12px;">
              <div class="code-header"><span class="code-lang">Python</span><button class="copy-btn" data-target="ep-default-py">Copy</button></div>
              <pre id="ep-default-py"><code>import requests

json = requests.get('http://localhost:3000/api/fuel-prices').json()
print(json['meta']['dataSources'])
print(json['data'][0]['name'])
print(json['data'][0]['sources'])</code></pre>
            </div>
          </div>

