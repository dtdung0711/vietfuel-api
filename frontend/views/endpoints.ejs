        <section id="regions" class="doc-section">
          <h2 class="section-title"><span class="section-num">05</span> <span data-vi="Phân vùng giá xăng dầu" data-en="Price Region Classification">Phân vùng giá xăng dầu</span></h2>
          <p data-vi="Theo quy định hiện hành, giá xăng dầu bán lẻ tại Việt Nam được phân thành 2 vùng:"
             data-en="Per current regulations, Vietnam's retail fuel prices are divided into 2 regions:">
            Theo quy định, giá xăng dầu được chia thành 2 vùng tại Việt Nam:
          </p>

          <div class="schema-table-wrap">
            <table class="schema-table">
              <thead>
                <tr>
                  <th data-vi="VÙNG" data-en="REGION">VÙNG</th>
                  <th data-vi="MÔ TẢ" data-en="DESCRIPTION">MÔ TẢ</th>
                  <th data-vi="PHẠM VI" data-en="SCOPE">PHẠM VI</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong data-vi="Vùng 1" data-en="Region 1">Vùng 1</strong></td>
                  <td data-vi="Địa bàn gần kho đầu mối, hạ tầng thuận lợi. Giá tiêu chuẩn." data-en="Near depots and infrastructure hubs. Standard price.">Gần kho đầu mối. Giá tiêu chuẩn.</td>
                  <td data-vi="48 tỉnh/thành (toàn tỉnh hoặc phần lớn)" data-en="48 provinces/cities (full or majority)">48 tỉnh thành</td>
                </tr>
                <tr>
                  <td><strong data-vi="Vùng 2" data-en="Region 2">Vùng 2</strong></td>
