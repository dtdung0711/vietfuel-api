<%- include('partials/header', { title: 'Vietnam Fuel Price API' , activeMenu: 'home' , bodyClass: 'home-page' }) %>

  <main class="main-content">
    <div class="hero">
      <div class="container animate-fade-in">
        <div class="hero-layout">
          <!-- Left Content -->
          <div class="hero-content">
            <div class="hero-badge animate-delay-1">
              <span class="live-dot active"></span>
              <span data-vi="Dịch vụ đang hoạt động" data-en="Service is operational">Dịch vụ đang hoạt động</span>
            </div>
            <h1 class="hero-title animate-delay-1">VIETNAM FUEL<br><span>PRICE API</span></h1>

            <p class="hero-sub animate-delay-2" data-vi="Cập nhật tự động — 11 Nguồn dữ liệu — 63 Tỉnh thành"
              data-en="Automated Updates — 11 Data Sources — 63 Provinces">
              Cập nhật tự động — 11 Nguồn dữ liệu — 63 Tỉnh thành
            </p>

            <p class="hero-desc animate-delay-2"
              data-vi="Dữ liệu giá xăng dầu bán lẻ được tổng hợp trực tiếp từ các nguồn uy tín, làm mới tự động theo Nghị định 80/2023/NĐ-CP. Kiến trúc ưu tiên độ trễ cực thấp."
              data-en="Retail fuel price data aggregated directly from official sources, adaptively refreshed per Decree 80/2023/ND-CP. Architecture prioritizes ultra-low latency.">
              Dữ liệu giá xăng dầu bán lẻ được tổng hợp trực tiếp từ các nguồn uy tín, làm mới tự động theo Nghị định 80/2023/NĐ-CP. Kiến
              trúc ưu tiên độ trễ cực thấp.
            </p>

            <div class="hero-cta animate-delay-3">
              <a href="/endpoints" class="btn btn-primary hero-btn" data-vi="Xem tài liệu API"
                data-en="View Documentation">
                Xem tài liệu API
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </a>
              <a href="/live" class="btn btn-ghost hero-btn" data-vi="Xem giá thực tế" data-en="View Live Prices">Xem
                giá thực tế</a>
            </div>

            <!-- Trust Bar -->
            <div class="hero-trust animate-delay-3">
              <span class="trust-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Open Source
              </span>
              <span class="trust-dot">·</span>
              <span class="trust-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <rect x="3" y="11" width="18" height="11" rx="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
                No Auth Required
              </span>
              <span class="trust-dot">·</span>
              <span class="trust-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                </svg>
                RESTful JSON
              </span>
              <span class="trust-dot">·</span>
              <span class="trust-item">MIT License</span>
            </div>
          </div>

          <!-- Right Content: Terminal Window -->
          <div class="hero-terminal animate-delay-2">
            <div class="terminal-header">
              <div class="terminal-dots">
                <div class="terminal-dot r"></div>
                <div class="terminal-dot y"></div>
                <div class="terminal-dot g"></div>
              </div>
              <div class="terminal-title">bash — quickstart</div>
            </div>
            <div class="terminal-body" id="hero-code-block">
              <div><span class="arg"># Lấy dữ liệu API ngay lập tức (cURL)</span></div>
              <div><span class="cmd">curl</span> <span class="arg">-X</span> GET <span
                  class="str">"http://localhost:3000/api/fuel-prices"</span> \</div>
              <div> <span class="arg">-H</span> <span class="str">"Accept: application/json"</span></div>
              <br>
              <div><span class="arg"># Gắn thẳng vào giao diện của bạn (JS Fetch)</span></div>
              <div><span class="cmd">fetch</span>(<span class="str">'http://localhost:3000/api/fuel-prices'</span>)
              </div>
              <div> .<span class="cmd">then</span>(res => res.<span class="cmd">json</span>())</div>
              <div> .<span class="cmd">then</span>(data => {</div>
              <div> console.<span class="cmd">log</span>(<span class="str">`Giá Xăng RON 95-III:`</span>, data.<span
                  class="num">data</span>[<span class="num">0</span>].<span class="num">region1</span>);</div>
              <div> });</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="container main-content animate-fade-in animate-delay-3">

      <!-- ═ ABOUT SECTION ══════════════════════════ -->
      <!--
        FIX: section-title is now INSIDE the left column of the grid,
        so the right specs card aligns with the title, not the description.
      -->
      <section class="about-section doc-section">
        <div class="about-grid">
          <!-- Left: Title + Description + CTA -->
          <div class="about-left">
            <h2 class="section-title" data-vi="Giới thiệu VietFuelAPI" data-en="About VietFuelAPI">Giới thiệu
              VietFuelAPI</h2>
            <p class="qs-desc"
              data-vi="VietFuelAPI là cổng dữ liệu (data portal) giá xăng dầu thời gian thực miễn phí đầu tiên tại Việt Nam. Cung cấp nền tảng API tốc độ cao, giúp các nhà phát triển dễ dàng tích hợp bảng giá nhiên liệu vào ứng dụng của mình mà không cần thiết lập crawler phức tạp. Toàn bộ thông tin được tổng hợp, chuẩn hóa và đóng gói qua một Endpoint RESTful tiện lợi."
              data-en="VietFuelAPI is Vietnam's first free real-time fuel price data portal. A high-speed API platform helping developers integrate fuel price data without building complex crawlers.">
              VietFuelAPI là cổng dữ liệu (data portal) giá xăng dầu thời gian thực miễn phí đầu tiên tại Việt Nam. Cung
              cấp
              nền tảng API tốc độ cao, giúp các nhà phát triển dễ dàng tích hợp bảng giá nhiên liệu vào ứng dụng của
              mình mà
              không cần thiết lập crawler phức tạp. Toàn bộ thông tin được tổng hợp, chuẩn hóa và đóng gói qua một
              Endpoint
              RESTful tiện lợi.
            </p>
            <a href="/endpoints" class="about-cta" data-vi="Xem API Reference →" data-en="View API Reference →">Xem API
              Reference →</a>
          </div>
          <!-- Right: Tech Specs (starts at the same height as the title above) -->
          <dl class="about-specs">
            <div class="spec-row">
              <dt class="spec-key">Format</dt>
              <dd class="spec-val">JSON / REST</dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Auth</dt>
              <dd class="spec-val spec-good">Not Required</dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Refresh</dt>
              <dd class="spec-val">Adaptive (15m-6h)</dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Latency</dt>
              <dd class="spec-val">~50–100ms</dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Sources</dt>
              <dd class="spec-val">11 Scraper Nodes</dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">License</dt>
              <dd class="spec-val">MIT Open Source</dd>
            </div>
          </dl>
        </div>
      </section>

      <!-- ═ FEATURE BENTO GRID ══════════════════════════ -->
      <!--
        Proper bento grid: 3 equal columns, 2 rows.
        Row 1: Large cell (span 2) + small cell
        Row 2: Small cell + Large cell (span 2)
      -->
      <section class="bento-section doc-section">
        <h2 class="section-title" data-vi="Tại sao chọn VietFuelAPI?" data-en="Why VietFuelAPI?">Tại sao chọn
          VietFuelAPI?</h2>
        <div class="bento-grid">

          <!-- Row 1, Col 1-2: Large cell -->
          <div class="bento-cell bento-lg">
            <div class="bento-cell-top">
              <div class="bento-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
              </div>
              <h3 class="bento-title" data-vi="Tự động dự phòng đa nguồn" data-en="Multi-source Fallback">Tự động dự
                phòng đa nguồn</h3>
            </div>
            <p class="bento-desc"
              data-vi="Khi một scraper gặp lỗi, hệ thống tự chuyển sang nguồn dự phòng. Trường meta.primarySource trong mỗi response xác nhận rõ nguồn đang cung cấp dữ liệu thực tế — không cần đoán mò."
              data-en="When one scraper fails, the system automatically switches to a backup source. The meta.primarySource field in each response clearly confirms who is actually serving the data.">
              Khi một scraper gặp lỗi, hệ thống tự chuyển sang nguồn dự phòng. Trường <code
                class="bento-code">meta.primarySource</code> trong mỗi response xác nhận rõ nguồn đang cung cấp dữ liệu
              thực tế — không cần đoán mò.
            </p>
            <div class="bento-tag">Reliability</div>
          </div>

          <!-- Row 1, Col 3: Small cell -->
          <div class="bento-cell">
            <div class="bento-cell-top">
              <div class="bento-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="2" y1="12" x2="22" y2="12" />
                  <path
                    d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              </div>
              <h3 class="bento-title" data-vi="Phân vùng giá thông minh" data-en="Smart Region Logic">Phân vùng giá
                thông minh</h3>
            </div>
            <p class="bento-desc"
              data-vi="Tự động phân loại Vùng 1 & 2 cho 63 tỉnh thành, kể cả 4 tỉnh 'bán phần' có ranh giới huyện riêng biệt."
              data-en="Automatically classifies Region 1 & 2 for all 63 provinces, including 4 split provinces with district-level boundaries.">
              Tự động phân loại Vùng 1 &amp; 2 cho 63 tỉnh thành, kể cả 4 tỉnh "bán phần" có ranh giới huyện riêng biệt.
            </p>
            <div class="bento-tag">Coverage</div>
          </div>

          <!-- Row 2, Col 1: Small cell -->
          <div class="bento-cell">
            <div class="bento-cell-top">
              <div class="bento-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <polyline points="16 18 22 12 16 6" />
                  <polyline points="8 6 2 12 8 18" />
                </svg>
              </div>
              <h3 class="bento-title" data-vi="Schema thống nhất" data-en="Unified Schema">Schema thống nhất</h3>
            </div>
            <p class="bento-desc"
              data-vi="11 nguồn, 11 cấu trúc HTML khác nhau — toàn bộ chuẩn hóa về 1 JSON schema. Không cần xử lý parser riêng."
              data-en="11 sources, 11 different HTML structures — all normalized to a single JSON schema. No need to handle individual parsers.">
              11 nguồn, 11 cấu trúc HTML khác nhau — toàn bộ chuẩn hóa về 1 JSON schema. Không cần xử lý parser riêng.
            </p>
            <div class="bento-tag">DX</div>
          </div>

          <!-- Row 2, Col 2-3: Large cell -->
          <div class="bento-cell bento-lg">
            <div class="bento-cell-top">
              <div class="bento-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
              </div>
              <h3 class="bento-title" data-vi="RAM Cache — không cold start" data-en="RAM Cache — No Cold Start">RAM
                Cache — không cold start</h3>
            </div>
            <p class="bento-desc"
              data-vi="Default endpoint phục vụ dữ liệu trực tiếp từ RAM cache, không có cold start, độ trễ phản hồi trung bình dưới 100ms. Chỉ endpoint tra cứu tỉnh thành mới thực hiện scrape on-demand."
              data-en="Default endpoint serves data directly from RAM cache with no cold start and average response latency under 100ms. Only the province lookup endpoint performs on-demand scraping.">
              Default endpoint phục vụ dữ liệu trực tiếp từ RAM cache, không có cold start, độ trễ phản hồi trung bình
              dưới 100ms. Chỉ endpoint tra cứu tỉnh thành mới thực hiện scrape on-demand.
            </p>
            <div class="bento-tag">Performance</div>
          </div>

        </div>
      </section>

      <!-- ═ API ARCHITECTURE DIAGRAM ══════════════════════════ -->
      <section class="api-flow-section doc-section">
