<%- include('partials/header', { title: 'Live Data — VietFuelAPI', activeMenu: 'live', bodyClass: '' }) %>

<main class="main-content">

  <!-- ── PAGE HERO ───────────────────────────────────────────── -->
  <div class="page-hero">
    <div class="container animate-fade-in">
      <p class="page-overline" data-vi="Dữ liệu thực" data-en="Live Data">Dữ liệu thực</p>
      <h1 class="page-title">LIVE FUEL PRICES</h1>
      <p class="page-subtitle"
         data-vi="Dữ liệu giá xăng dầu từ 11 nguồn tích hợp — cập nhật thông minh theo Nghị định 80/2023 (15 phút/lần vào Thứ Năm), bao gồm tra cứu theo 63 tỉnh thành."
         data-en="Fuel price data from 11 integrated sources — adaptive updates per Decree 80/2023 (every 15 min on Thursdays), including per-province lookup across 63 provinces.">
        Dữ liệu giá xăng dầu từ 11 nguồn tích hợp — cập nhật thông minh theo Nghị định 80/2023 (15 phút/lần vào Thứ Năm), bao gồm tra cứu theo 63 tỉnh thành.
      </p>
    </div>
  </div>

  <div class="container live-page-shell animate-fade-in animate-delay-1">

    <!-- ── STATS BAR ─────────────────────────────────────────── -->
    <div class="live-stats-bar" id="liveStatsBar">
      <div class="live-stat-card">
        <span class="lsc-label" data-vi="Ngày niêm yết" data-en="Price Date">Ngày niêm yết</span>
        <span class="lsc-value" id="statPriceDate">—</span>
        <span class="lsc-sub" data-vi="Kỳ điều hành giá" data-en="Regulatory period">Kỳ điều hành giá</span>
      </div>
      <div class="live-stat-card">
        <span class="lsc-label" data-vi="Cập nhật lúc" data-en="Last Updated">Cập nhật lúc</span>
        <span class="lsc-value" id="statUpdatedAt">—</span>
        <span class="lsc-sub" data-vi="Lần cào gần nhất" data-en="Last scrape time">Lần cào gần nhất</span>
      </div>
      <div class="live-stat-card">
        <span class="lsc-label" data-vi="Nguồn hoạt động" data-en="Active Sources">Nguồn hoạt động</span>
        <span class="lsc-value lsc-ok" id="statSources">—</span>
        <span class="lsc-sub" data-vi="Trên tổng 11 nguồn" data-en="Out of 11 sources">Trên tổng 11 nguồn</span>
      </div>
    </div>

    <!-- ── LIVE BADGE + REFRESH COUNTDOWN ───────────────────── -->
    <div class="live-header-row">
      <div style="display:flex; align-items:center; gap: var(--space-md); flex-wrap:wrap;">
        <span class="live-badge">
          <i data-lucide="activity" width="12" height="12"></i>
          LIVE
        </span>
        <div class="live-status-bar">
          <span id="liveStatusText" class="live-status-text"
                data-vi="Đang tải dữ liệu..." data-en="Loading...">Đang tải dữ liệu...</span>
        </div>
      </div>
      <div class="live-refresh-info">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
        </svg>
        <span data-vi="Làm mới lại sau:" data-en="Refresh in:">Làm mới lại sau:</span>
        <span id="liveCountdown">—</span>
      </div>
    </div>

    <!-- ── SOURCE TABS ───────────────────────────────────────── -->
    <div class="source-tabs" id="sourceTabs" role="tablist">
      <button class="source-tab-btn source-tab-active" data-source="unified" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#ff6300;"></i>
        <span data-vi="Tổng hợp" data-en="All Sources">Tổng hợp</span>
      </button>
      <button class="source-tab-btn" data-source="petrolimex" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#0088cc;"></i>
        Petrolimex
      </button>
      <button class="source-tab-btn" data-source="pvoil" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#ed1c24;"></i>
        PVOil
      </button>
      <button class="source-tab-btn" data-source="mipec" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#d11241;"></i>
        Mipec
      </button>
      <button class="source-tab-btn" data-source="webgia" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#4ade80;"></i>
        WebGia
      </button>
      <button class="source-tab-btn" data-source="comeco" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#2e3192;"></i>
        COMECO
      </button>
      <button class="source-tab-btn" data-source="saigonpetro" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#f7a81b;"></i>
        Saigon Petro
      </button>
      <button class="source-tab-btn" data-source="petrotimes" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#ff5e14;"></i>
        Petro Times
      </button>
      <button class="source-tab-btn" data-source="giaxanghomnay" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#ff3366;"></i>
        GiaXangHomNay
      </button>
      <button class="source-tab-btn" data-source="province" role="tab">
        <i data-lucide="circle" class="tab-icon" style="color:#8b5cf6;"></i>
        <span data-vi="63 Tỉnh thành" data-en="63 Provinces">63 Tỉnh thành</span>
      </button>
    </div>

    <!-- ── PROVINCE SELECTOR ─────────────────────────────────── -->
    <div id="provinceSelectorWrap" class="province-selector-wrap" style="display:none;">
      <label class="province-label" for="provinceSelect"
             data-vi="Chọn tỉnh / thành phố:" data-en="Select province:">Chọn tỉnh / thành phố:</label>
      <select id="provinceSelect" class="province-select">
        <option value="">— Chọn tỉnh thành —</option>
      </select>
      <span id="provinceRegionBadge" class="province-region-badge" style="display:none;"></span>
    </div>

    <!-- ── FUEL CARDS PANEL (default + single-source view) ───── -->
    <div id="fuelCardsPanel">
      <p class="live-section-title" id="cardsPanelTitle"
         data-vi="Giá xăng dầu" data-en="Fuel Prices">Giá xăng dầu</p>
      <div id="fuelCardsGrid" class="fuel-cards-grid">
        <!-- Skeleton loaders -->
        <div class="fuel-card-skeleton"></div>
        <div class="fuel-card-skeleton"></div>
        <div class="fuel-card-skeleton"></div>
        <div class="fuel-card-skeleton"></div>
        <div class="fuel-card-skeleton"></div>
        <div class="fuel-card-skeleton"></div>
      </div>
      <div id="cardsError" class="live-error" style="display:none;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p id="cardsErrorText" data-vi="Lỗi tải dữ liệu." data-en="Failed to load data.">Lỗi tải dữ liệu.</p>
        <button class="btn btn-ghost" onclick="window.fetchLiveData()" style="margin-top:4px;"
                data-vi="Thử lại" data-en="Retry">Thử lại</button>
      </div>
    </div>

    <!-- ── COMPARISON TABLE (unified view only) ──────────────── -->
    <div id="comparisonPanel" style="display:none;">
      <p class="live-section-title"
         data-vi="So sánh theo nguồn" data-en="Source Comparison">So sánh theo nguồn</p>
      <div class="live-table-wrap">
        <table id="liveTable" class="live-table">
          <thead><tr id="tableHeader"></tr></thead>
          <tbody id="tableBody"></tbody>
        </table>
        <div id="loadingIndicator" class="live-loading" style="display:none;">
          <div class="loading-spinner"></div>
          <span data-vi="Đang đồng bộ dữ liệu..." data-en="Syncing with sources...">Đang đồng bộ dữ liệu...</span>
        </div>
        <div id="errorIndicator" class="live-error" style="display:none;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <p id="errorText" data-vi="Lỗi tải dữ liệu." data-en="Failed to load data.">Lỗi tải dữ liệu.</p>
          <button class="btn btn-ghost" onclick="window.fetchLiveData()"
                  data-vi="Thử lại" data-en="Retry">Thử lại</button>
        </div>
      </div>
    </div>


    <!-- ── RAW JSON ACCORDION ────────────────────────────────── -->
    <div class="raw-accordion" id="rawAccordion">
      <div class="raw-accordion-header" id="rawAccordionToggle" role="button" tabindex="0"
           aria-expanded="false" aria-controls="rawAccordionBody">
        <span class="raw-accordion-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
          </svg>
          <span data-vi="Dữ liệu Raw JSON" data-en="Raw JSON Response">Dữ liệu Raw JSON</span>
        </span>
        <div style="display:flex; align-items:center; gap:var(--space-sm);">
          <button class="copy-btn" id="rawCopyBtn" data-target="rawJsonCode"
                  data-vi="Copy" data-en="Copy">Copy</button>
          <svg class="raw-accordion-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </div>
      <div class="raw-accordion-body" id="rawAccordionBody">
        <div class="code-block" style="border:none; border-radius:0; margin:0;">
          <pre class="raw-json-pre"><code id="rawJsonCode" class="language-json">{ /* loading... */ }</code></pre>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('partials/footer', { extraScripts: `<script src="/js/live.js"></script>` }) %>