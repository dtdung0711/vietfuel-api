  <script>
    (function() {
      const canvas = document.getElementById('flickering-grid-footer');
      if (!canvas) return;
      const ctx = canvas.getContext('2d', { alpha: true });
      const config = {
        squareSize: 4, gridGap: 12,
        color: [255, 140, 0], // Orange
        maxOpacity: 0.42, flickerChance: 0.045, transitionSpeed: 0.08
      };
      let cols, rows, squares = [];
      function resize() {
        const parent = canvas.parentElement;
        const dpr = window.devicePixelRatio || 1;
        canvas.width = parent.clientWidth * dpr;
        canvas.height = parent.clientHeight * dpr;
        ctx.scale(dpr, dpr);
        const cellSize = config.squareSize + config.gridGap;
        cols = Math.ceil(parent.clientWidth / cellSize);
        rows = Math.ceil(parent.clientHeight / cellSize);
        squares = Array.from({ length: cols * rows }, () => ({
          curr: Math.random() * config.maxOpacity,
          target: Math.random() * config.maxOpacity
        }));
      }
      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const cellSize = config.squareSize + config.gridGap;
        for (let i = 0; i < squares.length; i++) {
          let sq = squares[i];
          if (Math.random() < config.flickerChance) sq.target = Math.random() * config.maxOpacity;
          sq.curr += (sq.target - sq.curr) * config.transitionSpeed;
          if (sq.curr < 0.01) continue;
          const x = (i % cols) * cellSize;
          const y = Math.floor(i / cols) * cellSize;
          ctx.fillStyle = `rgba(${config.color[0]}, ${config.color[1]}, ${config.color[2]}, ${sq.curr})`;
          ctx.fillRect(x, y, config.squareSize, config.squareSize);
        }
        requestAnimationFrame(animate);
      }
      window.addEventListener('resize', resize);
      resize();
      requestAnimationFrame(animate);
    })();
  </script>
