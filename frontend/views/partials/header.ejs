<!DOCTYPE html>
<html lang="vi" data-lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <meta name="description" content="Vietnam Fuel Price API" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=1.4.0" />
  <!-- Lucide Icons — served locally to bypass CSP -->
  <script src="/js/vendor/lucide.min.js" defer></script>
</head>
<body <%- (typeof bodyClass !== 'undefined' && bodyClass) ? `class="${bodyClass}"` : '' %>>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <img src="/brand/VietFuelAPI_header.png" alt="VietFuelAPI Logo" class="logo-img" />
        <span class="logo-text">VietFuel<span class="logo-accent">API</span></span>
      </a>
      <button class="mobile-toggle" id="mobileNavToggle" aria-label="Mở menu">
        <div class="hamburger-icon" id="hamburgerIcon">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </button>

      <nav class="header-nav" id="headerNav" aria-label="Điều hướng chính">
        <a href="/" class="nav-link <%= (typeof activeMenu !== 'undefined' && activeMenu === 'home') ? 'nav-active' : '' %>" data-vi="Trang chủ" data-en="Home">Trang chủ</a>
        <a href="/endpoints" class="nav-link <%= (typeof activeMenu !== 'undefined' && activeMenu === 'endpoints') ? 'nav-active' : '' %>" data-vi="API Reference" data-en="API Reference">API Reference</a>
        <a href="/live" class="nav-link <%= (typeof activeMenu !== 'undefined' && activeMenu === 'live') ? 'nav-active' : '' %>" data-vi="Dữ liệu thực" data-en="Live Data">Dữ liệu thực</a>
      </nav>

      <div class="header-actions">
        <a href="https://github.com/TranQui004/vietfuel-api" target="_blank" rel="noopener noreferrer" class="github-btn" aria-label="GitHub Repository">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
        </a>
        <button class="lang-toggle" id="langToggle" aria-label="Chuyển ngôn ngữ">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <line x1="2" y1="12" x2="22" y2="12" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
          <span id="langLabel">EN</span>
        </button>
      </div>
    </div>
  </header>
